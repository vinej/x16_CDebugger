# ---------------------------------------------------------------------------
# Third-party pieces at the repo root (see README "Installing the untracked
# pieces"): emulators, compilers/SDKs, docs.
# ---------------------------------------------------------------------------
/box16
/box16-src
/emulator
/doc
# Oscar64 compiler, repo-local copy
/oscar64-sdk
# llvm-mos SDK, repo-local full copy (bin, lib, mos-platform, ...)
/llvm-mos
# cc65 toolchain, repo-local copy (bin, include, lib, cfg, asminc, target)
/cc65-sdk

# ---------------------------------------------------------------------------
# cc65/ subproject (cc65 toolkit): generated output and third-party copies
# (from vinej/x16_clib) are untracked; the hand-authored project-config.json,
# ld65-cx16.cmd, examples/ and .vscode configs ARE tracked.
# ---------------------------------------------------------------------------
/cc65/build/
/cc65/include_ca65/
/cc65/dist_ca65/
/cc65/src_ca65/

# ---------------------------------------------------------------------------
# oscar64/ subproject (Oscar64 toolkit): generated output and third-party
# copies (from vinej/x16_clib) are untracked; the hand-authored
# project-config.json, examples/, build_oscar64.ps1 and .vscode configs
# ARE tracked. build/ is VS64's output (bounce.prg, .asm, .map, .lbl,
# .dbj, ninja files); build_oscar64/ is the stand-alone script's output.
# ---------------------------------------------------------------------------
/oscar64/build/
/oscar64/build_oscar64/
/oscar64/src_oscar64/

# ---------------------------------------------------------------------------
# llvm/ subproject (llvm-mos toolkit): generated output and third-party
# copies (from vinej/x16_clib) are untracked; the hand-authored
# project-config.json, examples/ and .vscode configs ARE tracked.
# ---------------------------------------------------------------------------
/llvm/build/
/llvm/include_llvm/
/llvm/dist_llvm/
llvm/.vscode/c_cpp_properties.json
llvm/.vscode/ipch/
llvm/.vscode/*.vsidx
llvm/.vscode/browse.vc.db*

# ---------------------------------------------------------------------------
# VS64 editor integration (generated), keep the hand-authored config
# ---------------------------------------------------------------------------
# settings.json, tasks.json and launch.json are hand-authored and tracked;
# c_cpp_properties.json and the IntelliSense caches are generated by VS64.
# (Applies to any .vscode folder: oscar64/.vscode, llvm/.vscode, ...)
**/.vscode/c_cpp_properties.json
**/.vscode/ipch/
**/.vscode/*.vsidx
**/.vscode/browse.vc.db*

# ---------------------------------------------------------------------------
# Emulator runtime scratch
# ---------------------------------------------------------------------------
# Box16 / x16emu drop these next to their working directory.
dump.txt
dump-*.txt
memory_stats.txt
# Binary-monitor wire traces (BOX16_BINMON_LOG) and other stray logs.
*.log

# ---------------------------------------------------------------------------
# Box16 fork build artifacts (box16-src is its own git repo with its own
# .gitignore; these patterns only matter if that clone is flattened here)
# ---------------------------------------------------------------------------

#box16-src/build/vs2022/out/
#box16-src/build/vs2022/.vs/
#box16-src/build/vs2022/*.user
*.obj
*.pdb
*.ilk

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
*~
*.swp
