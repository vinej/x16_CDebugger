{
    // Prog8 is NOT a VS64 toolkit (VS64 has no prog8/64tass support), so
    // this project has no project-config.json and no F5 attach debugging.
    // What you get today: build + run + SYMBOLIC debugging inside Box16's
    // own ImGui debugger (labels + %breakpoint entries loaded via -sym).
    // Full VSCode source-level debugging is the goal of the separate
    // X16_Prog8Debugger project.
    "version": "2.0.0",
    "tasks": [
        {
            // prog8c needs Java 11+ (NOT the system default Java 8) and
            // 64tass on the PATH (both live in ..\prog8-sdk). If your JDK
            // lives elsewhere, change the java.exe path below.
            "label": "build project",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "command": "powershell",
            "args": [
                "-NoProfile", "-Command",
                "$env:PATH = '${workspaceFolder}\\..\\prog8-sdk;' + $env:PATH; & 'C:\\Program Files\\Eclipse Adoptium\\jdk-21.0.3.9-hotspot\\bin\\java.exe' -jar '${workspaceFolder}\\..\\prog8-sdk\\prog8c.jar' -target cx16 -asmlist -out build examples/bounce.p8"
            ],
            "problemMatcher": []
        },
        {
            "label": "run in x16emu (standard)",
            "type": "shell",
            "command": "${workspaceFolder}\\..\\emulator\\x16emu.exe",
            "args": [
                "-rom", "${workspaceFolder}\\..\\emulator\\rom.bin",
                "-prg", "${workspaceFolder}\\build\\bounce.prg",
                "-run",
                "-scale", "2"
            ],
            "dependsOn": "build project",
            "problemMatcher": []
        },
        {
            "label": "kill stale box16",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile", "-Command",
                "Stop-Process -Name box16 -Force -ErrorAction SilentlyContinue; exit 0"
            ],
            "presentation": { "reveal": "silent" },
            "problemMatcher": []
        },
        {
            // Symbolic debugging in Box16's built-in ImGui debugger:
            // -sym loads prog8's .vice-mon-list (labels + %breakpoint
            // entries). The binary monitor is enabled too, so external
            // tools (e.g. the future X16_Prog8Debugger adapter) can
            // attach on port 6502.
            "label": "debug in Box16 (symbolic)",
            "type": "shell",
            "command": "${workspaceFolder}\\..\\box16-src\\build\\vs2022\\out\\x64\\Release\\box16.exe",
            "args": [
                "-ignore_ini",
                "-binarymonitor",
                "-rom", "${workspaceFolder}\\..\\emulator\\rom.bin",
                "-prg", "${workspaceFolder}\\build\\bounce.prg",
                "-run",
                "-sym", "${workspaceFolder}\\build\\bounce.vice-mon-list",
                "-scale", "2"
            ],
            "dependsOn": ["build project", "kill stale box16"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
